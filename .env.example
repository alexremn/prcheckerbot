# ===========================================
# GitHub App Configuration (Required)
# ===========================================

# Your GitHub App's ID (found in app settings)
APP_ID=

# Webhook secret (configured when creating the GitHub App)
WEBHOOK_SECRET=

# Private key for the GitHub App
# Option 1: Path to the .pem file
# PRIVATE_KEY_PATH=./private-key.pem

# Option 2: The actual key content (with newlines as \n)
# PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ===========================================
# Local Development (Optional)
# ===========================================

# For local development, use smee.io to receive webhooks
# Create a channel at https://smee.io/new and paste the URL here
WEBHOOK_PROXY_URL=

# ===========================================
# Optional Settings
# ===========================================

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Optional: log level for the HTTP request logger (default: warn).
# Set to "info" to restore Probot's per-request webhook logs.
# HTTP_LOG_LEVEL=warn

# Port to run the server on (default: 3000)
PORT=3000

# Optional: path to a custom checker config JSON file
# Default: ./config/default.json
# PR_CHECKER_CONFIG_PATH=./config/my-config.json
